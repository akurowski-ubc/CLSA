# Air pollution by income category dashboard
air_income_vars <- list(
list(col = "pm25_1yr_com", title = "PM2.5 by Income Group", y_lab = "PM2.5 (µg/m³)"),
list(col = "no2_1yr_com",  title = "NO2 by Income Group",   y_lab = "NO2 (ppb)"),
list(col = "so2_1yr_com",  title = "SO2 by Income Group",   y_lab = "SO2 (ppb)"),
list(col = "o3_1yr_com",   title = "Ozone by Income Group", y_lab = "Ozone (ppb)")
)
air_income_plots <- list()
for (v in air_income_vars) {
p <- ggplot(subset_data, aes(x = income_cat, y = .data[[v$col]])) +
geom_boxplot(fill = "#2C7FB8", outlier.alpha = 0.5, width = 0.6) +
labs(
title = v$title,
x = "Household Income",
y = v$y_lab
) +
report_theme +
theme(
plot.title = element_text(size = 9),
axis.text.x = element_text(angle = 45, hjust = 1)  # angled labels if income categories are long
)
air_income_plots[[v$col]] <- p
}
dashboard_air_income <- wrap_plots(air_income_plots, ncol = 2) &
theme(
plot.title = element_text(size = 13, face = "bold"),
axis.title = element_text(size = 11),
axis.text = element_text(size = 9),
plot.margin = margin(t = 15, r = 15, b = 15, l = 15),
plot.background = element_rect(color = "grey60", linewidth = 1, fill = "white"),
panel.background = element_rect(fill = "white")
)
dashboard_air_income <- dashboard_air_income +
plot_annotation(
title = "Air Pollution by Household Income",
theme = theme(
plot.title = element_text(hjust = 0.5, face = "bold", size = 22),
plot.margin = margin(t = 20, r = 10, b = 10, l = 10),
plot.background = element_rect(fill = "grey90", color = NA)
)
)
